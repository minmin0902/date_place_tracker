# Supabase (Settings → API in Supabase dashboard)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Maps JavaScript API key
# https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=

# Optional: enable local/no-auth mode for development (stores data in localStorage)
# set to "true" to allow using the app without Supabase auth
VITE_ALLOW_NO_AUTH=false
